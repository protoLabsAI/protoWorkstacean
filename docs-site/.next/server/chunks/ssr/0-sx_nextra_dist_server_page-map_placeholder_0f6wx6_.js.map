ents.td><_components.code>{"{}"}</_components.code></_components.td><_components.td>{"Discord channel IDs ("}<_components.code>{"general"}</_components.code>{", "}<_components.code>{"updates"}</_components.code>{", "}<_components.code>{"dev"}</_components.code>{", "}<_components.code>{"alerts"}</_components.code>{", "}<_components.code>{"releases"}</_components.code>{")"}</_components.td></_components.tr></_components.tbody></_components.table>{"\n"}<_components.hr />{"\n"}<_components.h2 id={toc[3].id}>{toc[3].value}</_components.h2>{"\n"}<_components.p><_components.code>{"lib/project-schema.ts"}</_components.code>{" defines the Zod schema for "}<_components.code>{"workspace/projects.yaml"}</_components.code>{" entries. It is used by:"}</_components.p>{"\n"}<_components.ul>{"\n"}<_components.li><_components.code>{"lib/plugins/onboarding.ts"}</_components.code>{" — validates each new entry before writing (step 7 fails if validation fails)"}</_components.li>{"\n"}<_components.li><_components.code>{"lib/plugins/a2a.ts"}</_components.code>{" — validates on load (warns and skips invalid entries)"}</_components.li>{"\n"}</_components.ul>{"\n"}<_components.h3 id={toc[4].id}>{toc[4].value}</_components.h3>{"\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n"}<_components.table><_components.thead><_components.tr><_components.th>{"Field"}</_components.th><_components.th>{"Required"}</_components.th><_components.th>{"Description"}</_components.th></_components.tr></_components.thead><_components.tbody><_components.tr><_components.td><_components.code>{"slug"}</_components.code></_components.td><_components.td>{"✅"}</_components.td><_components.td>{"Unique project slug"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"github"}</_components.code></_components.td><_components.td>{"✅"}</_components.td><_components.td><_components.code>{"\"owner/repo\""}</_components.code>{" format"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"status"}</_components.code></_components.td><_components.td>{"✅"}</_components.td><_components.td>{"Project status string"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"discord.dev"}</_components.code></_components.td><_components.td>{"✅"}</_components.td><_components.td>{"Dev channel ID (may be empty string until channel is created)"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"title"}</_components.code></_components.td><_components.td /><_components.td>{"Human-readable name"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"defaultBranch"}</_components.code></_components.td><_components.td /><_components.td>{"Git default branch"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"team"}</_components.code></_components.td><_components.td /><_components.td>{"Team assignment"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"agents"}</_components.code></_components.td><_components.td /><_components.td>{"List of agent identifiers"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"planeProjectId"}</_components.code></_components.td><_components.td /><_components.td>{"UUID of the corresponding Plane project"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"onboardedAt"}</_components.code></_components.td><_components.td /><_components.td>{"ISO 8601 timestamp of onboarding"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"onboardingState"}</_components.code></_components.td><_components.td /><_components.td>{"Per-step status tracking ("}<_components.code>{"ok"}</_components.code>{" | "}<_components.code>{"skip"}</_components.code>{" | "}<_components.code>{"error"}</_components.code>{")"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"googleWorkspace.driveFolderId"}</_components.code></_components.td><_components.td /><_components.td>{"Google Drive folder ID created during onboarding"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"googleWorkspace.sharedDocId"}</_components.code></_components.td><_components.td /><_components.td>{"Project spec/brief Google Doc ID"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"googleWorkspace.calendarId"}</_components.code></_components.td><_components.td /><_components.td>{"Project-scoped calendar ID"}</_components.td></_components.tr></_components.tbody></_components.table>{"\n"}<_components.h3 id={toc[5].id}>{toc[5].value}</_components.h3>{"\n"}<_components.pre tabIndex="0" data-language="typescript" data-word-wrap="" data-pagefind-ignore="all"><_components.code><_components.span><_components.span style={{
    "--shiki-light": "#6A737D",
    "--shiki-dark": "#6A737D"
  }}>{"// Validate a single raw entry"}</_components.span></_components.span>{"\n"}<_components.span><_components.span style={{
    "--shiki-light": "#6F42C1",
    "--shiki-dark": "#B392F0"
  }}>{"validateProjectEntry"}</_components.span><_components.span style={{
    "--shiki-light": "#24292E",
    "--shiki-dark": "#E1E4E8"
  }}>{"(raw: unknown): { ok: "}</_components.span><_components.span style={{
