rity:"}</_components.p>{"\n"}<_components.ol>{"\n"}<_components.li>{"Keep past PR decisions (highest value)"}</_components.li>{"\n"}<_components.li>{"Trim similar patterns from lowest-scored first"}</_components.li>{"\n"}<_components.li>{"Drop learnings summary last"}</_components.li>{"\n"}</_components.ol>{"\n"}<_components.h3 id={toc[6].id}>{toc[6].value}</_components.h3>{"\n"}<_components.p>{"When a developer dismisses a Quinn review comment, "}<_components.code>{"dismissal-tracker.ts"}</_components.code>{" records the dismissal in "}<_components.code>{"quinn-review-learnings"}</_components.code>{". "}<_components.code>{"low-signal-filter.ts"}</_components.code>{" uses this collection to suppress similar patterns in future reviews."}</_components.p>{"\n"}<_components.h3 id={toc[7].id}>{toc[7].value}</_components.h3>{"\n"}<_components.p>{"After a PR merges, "}<_components.code>{"indexPRHistory()"}</_components.code>{" (exported from "}<_components.code>{"review-pipeline.ts"}</_components.code>{") embeds the merged diff and stores it in "}<_components.code>{"quinn-pr-history"}</_components.code>{". This keeps the context collection current."}</_components.p>{"\n"}<_components.h3 id={toc[8].id}>{toc[8].value}</_components.h3>{"\n"}<_components.p>{"Collections are created on first use via "}<_components.code>{"initializeCollections()"}</_components.code>{" from "}<_components.code>{"src/services/qdrant/collections.ts"}</_components.code>{". This is idempotent — safe to call on every startup."}</_components.p>{"\n"}<_components.hr />{"\n"}<_components.h2 id={toc[9].id}>{toc[9].value}</_components.h2>{"\n"}<_components.p>{"Quinn’s LLM calls go through the system-wide "}<_components.code>{"BudgetTracker"}</_components.code>{" ("}<_components.code>{"lib/plugins/budget-tracker.ts"}</_components.code>{"), backed by SQLite ("}<_components.code>{"budget.db"}</_components.code>{")."}</_components.p>{"\n"}<_components.p><_components.strong>{"Per-PR cost limits"}</_components.strong>{" are enforced via the BudgetPlugin tier system:"}</_components.p>{"\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n"}<_components.table><_components.thead><_components.tr><_components.th>{"Tier"}</_components.th><_components.th>{"Max estimated cost"}</_components.th><_components.th>{"Behavior"}</_components.th></_components.tr></_components.thead><_components.tbody><_components.tr><_components.td>{"L0"}</_components.td><_components.td>{"< $0.10"}</_components.td><_components.td>{"Fully autonomous"}</_components.td></_components.tr><_components.tr><_components.td>{"L1"}</_components.td><_components.td>{"< $1.00"}</_components.td><_components.td>{"Proceeds, notifies ops channel"}</_components.td></_components.tr><_components.tr><_components.td>{"L2"}</_components.td><_components.td>{"< $5.00"}</_components.td><_components.td>{"Proceeds, logs warning"}</_components.td></_components.tr><_components.tr><_components.td>{"L3"}</_components.td><_components.td>{"≥ $5.00"}</_components.td><_components.td>{"Blocked — escalates to HITL"}</_components.td></_components.tr></_components.tbody></_components.table>{"\n"}<_components.p><_components.strong>{"Daily caps"}</_components.strong>{" (system-wide, not Quinn-specific):"}</_components.p>{"\n"}<_components.ul>{"\n"}<_components.li><_components.code>{"$10"}</_components.code>{" per project per day"}</_components.li>{"\n"}<_components.li><_components.code>{"$50"}</_components.code>{" total across all projects per day"}</_components.li>{"\n"}</_components.ul>{"\n"}<_components.p><_components.strong>{"Record ordering:"}</_components.strong>{" The ledger uses "}<_components.code>{"ORDER BY timestamp DESC, rowid DESC"}</_components.code>{" — in the case of two records with the same timestamp, the higher "}<_components.code>{"rowid"}</_components.code>{" (later insertion) is returned first. This matters when querying the "}<_components.code>{"cost_trail"}</_components.code>{" for L3 escalations."}</_components.p>{"\n"}<_components.p><_components.strong>{"Fallback:"}</_components.strong>{" If SQLite is unavailable, BudgetTracker falls back to an in-memory map with a write-ahead log (WAL). Records are drained to SQLite on recovery."}</_components.p>{"\n"}<_components.hr />{"\n"}<_components.h2 id={toc[10].id}>{toc[10].value}</_components.h2>{"\n"}<_components.h3 id={toc[11].id}>{toc[11].value}</_components.h3>{"\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n"}<_components.table><_components.thead><_components.tr><_components.th>{"Variable"}</_components.th><_components.th>{"Required"}</_components.th><_components.th>{"Description"}</_components.th></_components.tr></_components.thead><_components.tbody><_components.tr><_components.td><_components.code>{"GITHUB_TOKEN"}</_components.code></_components.td><_components.td>{"Yes (if no App)"}</_components.td><_components.td>{"PAT — enables GitHub plugin"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"GITHUB_WEBHOOK_SECRET"}</_components.code></_components.td><_components.td>{"Recommended"}</_components.td><_components.td>{"Validates "}<_components.code>{"X-Hub-Signature-256"}</_components.code></_components.td></_components.tr><_components.tr><_components.td><_components.code>{"GITHUB_WEBHOOK_PORT"}</_components.code></_components.td><_components.td>{"No"}</_components.td><_components.td>{"Webhook server port (default: "}<_components.code>{"8082"}</_components.code>{")"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"QUINN_APP_ID"}</_components.code></_components.td><_components.td>{"For bot identity"}</_components.td><_components.td>{"GitHub App ID — posts as "}<_components.code>{"protoquinn[bot]"}</_components.code></_components.td></_components.tr><_components.tr><_components.td><_components.code>{"QUINN_APP_PRIVATE_KEY"}</_components.code></_components.td><_components.td>{"For 