  }}>{":"}</_components.span><_components.span style={{
    "--shiki-light": "#005CC5",
    "--shiki-dark": "#79B8FF"
  }}>{" string"}</_components.span><_components.span style={{
    "--shiki-light": "#6A737D",
    "--shiki-dark": "#6A737D"
  }}>{"           // Discord user ID, \"auto\", or interface identifier"}</_components.span></_components.span>{"\n"}<_components.span><_components.span style={{
    "--shiki-light": "#24292E",
    "--shiki-dark": "#E1E4E8"
  }}>{"}"}</_components.span></_components.span></_components.code></_components.pre>{"\n"}<_components.h2 id={toc[4].id}>{toc[4].value}</_components.h2>{"\n"}<_components.p><_components.code>{"HITLPlugin"}</_components.code>{" ("}<_components.code>{"lib/plugins/hitl.ts"}</_components.code>{") is a Workstacean bus plugin that manages the in-memory state of pending approvals."}</_components.p>{"\n"}<_components.p><_components.strong>{"Subscriptions:"}</_components.strong></_components.p>{"\n"}<_components.ul>{"\n"}<_components.li><_components.code>{"hitl.request.#"}</_components.code>{" — stores the incoming HITLRequest in the pending Map; forwards to registered renderers"}</_components.li>{"\n"}<_components.li><_components.code>{"hitl.response.#"}</_components.code>{" — validates correlationId exists in Map; removes from Map; publishes to the "}<_components.code>{"replyTopic"}</_components.code>{" from the original request"}</_components.li>{"\n"}</_components.ul>{"\n"}<_components.p><_components.strong>{"In-memory Map:"}</_components.strong>{" keyed by "}<_components.code>{"correlationId"}</_components.code>{", value is the full HITLRequest. The Map is not persisted — a workstacean restart clears it. If a restart happens while an approval is pending, the HITLResponse will still arrive but the lookup will miss and the response will be dropped. The PlanStore SQLite checkpoint is durable; the plan can be manually resumed by injecting an HITLResponse via "}<_components.code>{"/publish"}</_components.code>{"."}</_components.p>{"\n"}<_components.p><_components.strong>{"Extension point — "}<_components.code>{"registerHITLRenderer"}</_components.code>{":"}</_components.strong></_components.p>{"\n"}<_components.pre tabIndex="0" data-language="typescript" data-word-wrap="" data-pagefind-ignore="all"><_components.code><_components.span><_components.span style={{
    "--shiki-light": "#6F42C1",
    "--shiki-dark": "#B392F0"
  }}>{"registerHITLRenderer"}</_components.span><_components.span style={{
    "--shiki-light": "#24292E",
    "--shiki-dark": "#E1E4E8"
  }}>{"(interfaceName: string, handler: ("}</_components.span><_components.span style={{
    "--shiki-light": "#E36209",
    "--shiki-dark": "#FFAB70"
  }}>{"request"}</_components.span><_components.span style={{
    "--shiki-light": "#D73A49",
    "--shiki-dark": "#F97583"
  }}>{":"}</_components.span><_components.span style={{
    "--shiki-light": "#6F42C1",
    "--shiki-dark": "#B392F0"
  }}>{" HITLRequest"}</_components.span><_components.span style={{
    "--shiki-light": "#24292E",
    "--shiki-dark": "#E1E4E8"
  }}>{") "}</_components.span><_components.span style={{
    "--shiki-light": "#D73A49",
    "--shiki-dark": "#F97583"
  }}>{"=>"}</_components.span><_components.span style={{
    "--shiki-light": "#005CC5",
    "--shiki-dark": "#79B8FF"
  }}>{" Promise"}</_components.span><_components.span style={{
    "--shiki-light": "#D73A49",
    "--shiki-dark": "#F97583"
  }}>{"<void>"}</_components.span><_components.span style={{
    "--shiki-light": "#24292E",
    "--shiki-dark": "#E1E4E8"
  }}>{")"}</_components.span></_components.span></_components.code></_components.pre>{"\n"}<_components.p>{"Each interface plugin (Discord, etc.) registers a renderer on startup. When a new HITLRequest arrives, the plugin calls all registered renderers for interfaces that match the "}<_components.code>{"source.interface"}</_components.code>{" in the original BusMessage. This means adding a new rendering surface (Slack, voice, API webhook) requires only registering a renderer — no changes to HITLPlugin, the bus, or Ava."}</_components.p>{"\n"}<_components.p><_components.strong>{"Expiry sweep:"}</_components.strong>{" runs every 60 seconds. Any HITLRequest where "}<_components.code>{"expiresAt < Date.now()"}</_components.code>{" is removed from the Map and a message is published to "}<_components.code>{"hitl.expired.{correlationId}"}</_components.code>{". Interface plugins can subscribe to "}<_components.code>{"hitl.expired.#"}</_components.code>{" to clean up rendered prompts (e.g., disable Discord buttons)."}</_components.p>{"\n"}<_components.h2 id={toc[5].id}>{toc[5].value}</_components.h2>{"\n"}<_components.h3 id={toc[6].id}>{toc[6].value}</_components.h3>{"\n"}<_components.p>{"Ava’s "}<_components.code>{"plan"}</_components.code>{" skill is non-blocking from the caller’s perspective:"}</_components.p>{"\n"}<_components.pre tabIndex="0" data-language="plaintext" data-word-wrap="" data-pagefind-ignore="all"><_components.code><_components.span><_components.span>{"1. Receive inbound message with skillHint \"plan\""}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"2. Return immediately: { status: \"pending_approval\", correlationId }"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"3. Async in background:"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"   a. Generate SPARC PRD (Specification, Pseudocode, Architecture, Refinement, Completion sections)"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"   b. Run antagonistic review:"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"      - Ava lens: operational feasibility, complexity, risk"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"      - Jon lens: strategic value, market positioning, ROI"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"      - Each produces a numeric score (0–10) and written verdict"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"   c. Checkpoint to PlanStore (SQLite, keyed by correlationId, 7-day TTL)"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"   d. Evaluate scores → HITL gate or auto-approve path"}</_components.span></_components.span></_components.code></_components.pre>{"\n"}<_components.h3 id={toc[7].id}>{toc[7].value}</_components.h3>{"\n"}<_components.p>{"Triggered when Workstacean receives an HITLResponse on the bus:"}</_components.p>{"\n"}<_components.pre tabIndex="0" data-language="plaintext" data-word-wrap="" data-pagefind-ignore="all"><_components.code><_components.span><_components.span>{"1. Restore PRD + review results from PlanStore by correlationId"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"2. Decision routing:"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"   approve → create board features (one feature per PRD section/milestone)"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"             stamp correlationId on each feature"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"             publish to plane.reply.{correlationId} → PlanePlugin syncs back"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"   reject  → archive plan in PlanStore (mark as rejected, no features created)"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"             post rejection notice to originating interface"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"   modify  → apply feedback to PRD (re-draft the affected sections)"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"             re-run antagonistic review with updated PRD"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"             re-emit HITLRequest (new expiresAt, same correlationId)"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"             loop restarts at the HITL gate"}</_components.span></_components.span></_components.code></_components.pre>{"\n"}<_components.h2 id={toc[8].id}>{toc[8].value}</_components.h2>{"\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n"}<_components.table><_components.thead><_components.tr><_components.th>{"Decision"}</_components.th><_components.th>{"What happens"}</_components.th></_components.tr></_components.thead><_components.tbody><_components.tr><_components.td><_components.code>{"approve"}</_components.code></_components.td><_components.td>{"Board features created, correlationId stamped, Plane issue → “In Progress” (if Plane-originated), summary comment posted to Plane issue"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"reject"}</_components.code></_components.td><_components.td>{"Plan archived in PlanStore, no features created, rejection notice sent to originating channel"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"modify"}</_components.code></_components.td><_components.td>{"PRD re-drafted with "}<_components.code>{"feedback"}</_components.code>{" applied, antagonistic review re-run, new HITLRequest emitted with same "}<_components.code>{"correlationId"}</_components.code>{" — the loop can repeat until approved or rejected"}</_components.td></_components.tr></_components.tbody></_components.table>{"\n"}<_components.p>{"For "}<_components.code>{"modify"}</_components.code>{", the "}<_components.code>{"feedback"}</_components.code>{" field in HITLResponse is required. Ava treats it as a diff instruction: “make the scope smaller”, “drop the third milestone”, “reframe as an internal tool not a product”. The re-drafted PRD replaces the checkpoint in PlanStore."}</_components.p>{"\n"}<_components.h2 id={toc[9].id}>{toc[9].value}</_components.h2>{"\n"}<_components.p>{"If the originating Plane issue has the "}<_components.code>{"auto"}</_components.code>{" label, the HITL gate is skipped entirely:"}</_components.p>{"\n"}<_components.ul>{"\n"}<_components.li>{"Workstacean’s "}<_components.code>{"PlanePlugin"}</_components.code>{" detects the "}<_components.code>{"auto"}</_components.code>{" label before publishing to the bus."}</_components.li>{"\n"}<_components.li>{"The bus message payload carries "}<_components.code>{"autoApprove: true"}</_components.code>{"."}</_components.li>{"\n"}<_components.li>{"Ava’s "}<_components.code>{"plan"}</_components.code>{" skill checks this flag after completing the PRD + review."}</_components.li>{"\n"}<_components.li>{"If set, it internally generates an HITLResponse with "}<_components.code>{"decision: \"approve\""}</_components.code>{" and "}<_components.code>{"decidedBy: \"auto\""}</_components.code>{" and calls "}<_components.code>{"plan_resume"}</_components.code>{" directly without publishing an HITLRequest."}</_components.li>{"\n"}<_components.li>{"No approval prompt is rendered anywhere."}</_components.li>{"\n"}</_components.ul>{"\n"}<_components.p>{"Use "}<_components.code>{"auto"}</_components.code>{" for trusted automation sources or low-stakes scaffolding tasks. Use "}<_components.code>{"plan"}</_components.code>{" for any idea that affects production infrastructure or significant engineering investment."}</_components.p>{"\n"}<_components.h2 id={toc[10].id}>{toc[10].value}</_components.h2>{"\n"}<_components.p>{"The HITLPlugin expiry sweep runs every 60 seconds. When a request expires:"}</_components.p>{"\n"}<_components.ol>{"\n"}<_components.li>{"The entry is removed from the pending Map."}</_components.li>{"\n"}<_components.li>{"A message is published to "}<_components.code>{"hitl.expired.{correlationId}"}</_components.code>{"."}</_components.li>{"\n"}<_components.li>{"The plan remains in PlanStore — it is not automatically rejected. A late HITLResponse injected after expiry will not be routed (Map miss) but the plan can still be manually resumed."}</_components.li>{"\n"}</_components.ol>{"\n"}<_components.p>{"The "}<_components.code>{"expiresAt"}</_components.code>{" value in HITLRequest is set by Ava at emit time. The default TTL for the pending Map entry is separate from the 7-day PlanStore TTL."}</_components.p>{"\n"}<_components.p>{"Interface plugins should subscribe to "}<_components.code>{"hitl.expired.#"}</_components.code>{" to handle expiry rendering (e.g., editing a Discord embed to show “Approval expired — re-trigger with /plan”)."}</_components.p>{"\n"}<_components.h2 id={toc[11].id}>{toc[11].value}</_components.h2>{"\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n"}<_components.table><_components.thead><_components.tr><_components.th>{"Origin"}</_components.th><_components.th>{"correlationId format"}</_components.th><_components.th>{"Example"}</_components.th></_components.tr></_components.thead><_components.tbody><_components.tr><_components.td>{"Plane issue"}</_components.td><_components.td><_components.code>{"plane-{issueId}"}</_components.code></_components.td><_components.td><_components.code>{"plane-abc123de-f456-..."}</_components.code></_components.td></_components.tr><_components.tr><_components.td>{"Discord / other interface"}</_components.td><_components.td><_components.code>{"workstacean-{channelId}"}</_components.code></_components.td><_components.td><_components.code>{"workstacean-1469080556720623699"}</_components.code></_components.td></_components.tr></_components.tbody></_components.table>{"\n"}<_components.p>{"The "}<_components.code>{"correlationId"}</_components.code>{" is stable across the entire lifecycle: PRD generation, HITL request/response, plan_resume, and Plane sync-back all use the same value. It is stamped on every board feature created during "}<_components.code>{"plan_resume"}</_components.code>{" so the lineage is traceable."}</_components.p>{"\n"}<_components.h2 id={toc[12].id}>{toc[12].value}</_components.h2>{"\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n"}<_components.table><_components.thead><_components.tr><_components.th>{"Topic"}</_components.th><_components.th>{"Publisher"}</_components.th><_components.th>{"Subscriber"}</_components.th><_components.th>{"Description"}</_components.th></_components.tr></_components.thead><_components.tbody><_components.tr><_components.td><_components.code>{"hitl.request.#"}</_components.code></_components.td><_components.td>{"Ava"}</_components.td><_components.td>{"HITLPlugin"}</_components.td><_components.td>{"Approval request after SPARC PRD + review"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"hitl.response.#"}</_components.code></_components.td><_components.td>{"Interface plugin"}</_components.td><_components.td>{"HITLPlugin"}</_components.td><_components.td>{"Human decision"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"hitl.pending.{correlationId}"}</_components.code></_components.td><_components.td>{"HITLPlugin"}</_components.td><_components.td>{"API callers"}</_components.td><_components.td>{"Unrouted requests (no matching interface)"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"hitl.expired.{correlationId}"}</_components.code></_components.td><_components.td>{"HITLPlugin"}</_components.td><_components.td>{"Any"}</_components.td><_components.td>{"Request TTL exceeded — 60s sweep"}</_components.td></_components.tr></_components.tbody></_components.table>{"\n"}<_components.h2 id={toc[13].id}>{toc[13].value}</_components.h2>{"\n"}<_components.h3 id={toc[14].id}>{toc[14].value}</_components.h3>{"\n"}<_components.p>{"The Discord plugin renders HITLRequests as message embeds with interactive buttons. The embed shows:"}</_components.p>{"\n"}<_components.ul>{"\n"}<_components.li><_components.code>{"title"}</_components.code>{" and "}<_components.code>{"summary"}</_components.code>{" from the request"}</_components.li>{"\n"}<_components.li>{"Ava and Jon verdict summaries with scores"}</_components.li>{"\n"}<_components.li>{"Approve / Reject / Modify buttons"}</_components.li>{"\n"}<_components.li>{"Expiry timestamp in the embed footer"}</_components.li>{"\n"}</_components.ul>{"\n"}<_components.p>{"Button interactions publish an HITLResponse to the bus with "}<_components.code>{"decidedBy"}</_components.code>{" set to the Discord user’s ID."}</_components.p>{"\n"}<_components.h3 id={toc[15].id}>{toc[15].value}</_components.h3>{"\n"}<_components.p>{"When the originating interface is Plane (issue with "}<_components.code>{"plan"}</_components.code>{" label), the HITLRequest routes to "}<_components.code>{"plane.reply.{correlationId}"}</_components.code>{". The PlanePlugin renders this as a comment on the Plane issue asking for approval, and a subsequent issue update or comment triggers the HITLResponse."}</_components.p>{"\n"}<_components.h3 id={toc[16].id}>{toc[16].value}</_components.h3>{"\n"}<_components.p>{"External services can poll "}<_components.code>{"hitl.pending.#"}</_components.code>{" by subscribing to the bus via the "}<_components.code>{"/publish"}</_components.code>{" endpoint or by calling "}<_components.code>{"GET /api/hitl/{correlationId}"}</_components.code>{" if the Workstacean HTTP API exposes it. This allows CI pipelines or other automated systems to act as approval sources without a UI."}</_components.p>{"\n"}<_components.h3 id={toc[17].id}>{toc[17].value}</_components.h3>{"\n"}<_components.pre tabIndex="0" data-language="typescript" data-word-wrap="" data-pagefind-ignore="all"><_components.code><_components.span><_components.span style={{
    "--shiki-light": "#6A737D",
    "--shiki-dark": "#6A737D"
  }}>{"// In your interface plugin's init():"}</_components.span></_components.span>{"\n"}<_components.span><_components.span style={{
    "--shiki-light": "#6F42C1",
    "--shiki-dark": "#B392F0"
  }}>{"registerHITLRenderer"}</_components.span><_components.span style={{
    "--shiki-light": "#24292E",
    "--shiki-dark": "#E1E4E8"
  }}>{"("}</_components.span><_components.span style={{
    "--shiki-light": "#032F62",
    "--shiki-dark": "#9ECBFF"
  }}>{"\"myinterface\""}</_components.span><_components.span style={{
    "--shiki-light": "#24292E",
    "--shiki-dark": "#E1E4E8"
  }}>{", "}</_components.span><_components.span style={{
    "--shiki-light": "#D73A49",
    "--shiki-dark": "#F97583"
  }}>{"async"}</_components.span><_components.span style={{
    "--shiki-light": "#24292E",
    "--shiki-dark": "#E1E4E8"
  }}>{" ("}</_components.span><_components.span style={{
    "--shiki-light": "#E36209",
    "--shiki-dark": "#FFAB70"
  }}>{"request"}</_components.span><_components.span style={{
    "--shiki-light": "#D73A49",
    "--shiki-dark": "#F97583"
  }}>{":"}</_components.span><_components.span style={{
    "--shiki-light": "#6F42C1",
    "--shiki-dark": "#B392F0"
  }}>{" HITLRequest"}</_components.span><_components.span style={{
    "--shiki-light": "#24292E",
    "--shiki-dark": "#E1E4E8"
  }}>{") "}</_components.span><_components.span style={{
    "--shiki-light": "#D73A49",
