  }}>{"  }"}</_components.span></_components.span>{"\n"}<_components.span><_components.span style={{
    "--shiki-light": "#24292E",
    "--shiki-dark": "#E1E4E8"
  }}>{"}"}</_components.span></_components.span></_components.code></_components.pre>{"\n"}<_components.h2 id={toc[11].id}>{toc[11].value}</_components.h2>{"\n"}<_components.p>{"The "}<_components.code>{"onboard_project"}</_components.code>{" skill (Step 9 of the onboarding chain, triggered on Ava) auto-creates a Plane project for newly onboarded repos:"}</_components.p>{"\n"}<_components.ol>{"\n"}<_components.li>{"Calls "}<_components.code>{"POST /api/v1/workspaces/protolabsai/projects/"}</_components.code>{" with the project name and identifier derived from the repo name."}</_components.li>{"\n"}<_components.li>{"Stores the returned "}<_components.code>{"plane_project_id"}</_components.code>{" in two places:\n"}<_components.ul>{"\n"}<_components.li><_components.code>{".automaker/settings.json"}</_components.code>{" inside the target repo"}</_components.li>{"\n"}<_components.li><_components.code>{"workspace/projects.yaml"}</_components.code>{" (the authoritative project registry in this repo)"}</_components.li>{"\n"}</_components.ul>{"\n"}</_components.li>{"\n"}</_components.ol>{"\n"}<_components.p>{"This means every onboarded project gets a matching Plane project without manual setup."}</_components.p>{"\n"}<_components.h2 id={toc[12].id}>{toc[12].value}</_components.h2>{"\n"}<_components.p><_components.code>{"plane-mcp-server"}</_components.code>{" is configured in Ava’s "}<_components.code>{".mcp.json"}</_components.code>{". All agents running on the Ava host inherit 55+ Plane MCP tools covering issues, cycles, modules, members, states, and projects. This allows agents to read and write Plane data directly as tool calls without going through the webhook flow."}</_components.p>{"\n"}<_components.h2 id={toc[13].id}>{toc[13].value}</_components.h2>{"\n"}<_components.ul>{"\n"}<_components.li><_components.strong>{"Signature"}</_components.strong>{": "}<_components.code>{"X-Plane-Signature: sha256=<hex>"}</_components.code>{" — HMAC-SHA256 of the raw body."}</_components.li>{"\n"}<_components.li><_components.strong>{"Deduplication"}</_components.strong>{": "}<_components.code>{"X-Plane-Delivery"}</_components.code>{" ring buffer (10,000 entries) prevents replay."}</_components.li>{"\n"}<_components.li><_components.strong>{"Async response"}</_components.strong>{": Plane receives "}<_components.code>{"200 OK"}</_components.code>{" immediately; processing runs async to avoid webhook timeouts."}</_components.li>{"\n"}</_components.ul>{"\n"}<_components.h2 id={toc[14].id}>{toc[14].value}</_components.h2>{"\n"}<_components.p><_components.strong>{"API path quirk"}</_components.strong>{": "}<_components.code>{"/api/v1/workspaces/..."}</_components.code>{" uses API-key auth; "}<_components.code>{"/api/workspaces/..."}</_components.code>{" is session-only. Both return 401 for unknown paths as well, which makes debugging confusing — a 401 does not always mean wrong credentials, it can mean the path is not registered. Always confirm the path prefix before concluding the API key is invalid."}</_components.p>{"\n"}<_components.p><_components.strong><_components.code>{"drop_params: true"}</_components.code>{" in LiteLLM"}</_components.strong>{": LangChain’s "}<_components.code>{"ChatOpenAI"}</_components.code>{" sends "}<_components.code>{"top_p: -1"}</_components.code>{" when routing through a Claude fallback. This is an invalid value that Claude rejects. "}<_components.code>{"drop_params: true"}</_components.code>{" is set in "}<_components.code>{"general_settings"}</_components.code>{" in the LiteLLM config, which strips unknown/invalid parameters before forwarding to the model backend. Without this, Plane-triggered plan requests that hit the Claude fallback fail immediately."}</_components.p>{"\n"}<_components.p><_components.strong>{"pendingIssues Map is ephemeral"}</_components.strong>{": See Section 5. A workstacean restart during an active HITL approval cycle loses the sync-back context. The PRD and features are safe (PlanStore is SQLite-backed); only the Plane issue state update is affected."}</_components.p>{"\n"}<_components.p><_components.strong>{"Webhook fires on updates too"}</_components.strong>{": The webhook is subscribed to all "}<_components.code>{"issue"}</_components.code>{" events including updates. If someone edits an already-processed issue and the "}<_components.code>{"plan"}</_components.code>{" label is still present, it will fire again. The 10k-entry deduplication ring by "}<_components.code>{"X-Plane-Delivery"}</_components.code>{" UUID prevents duplicate processing per delivery, but a new edit generates a new delivery UUID. The plan skill itself is idempotent at the PRD level (correlationId is stable), but be aware that editing an issue title after it has been processed will re-trigger the full flow."}</_components.p>{"\n"}<_components.h2 id={toc[15].id}>{toc[15].value}</_components.h2>{"\n"}<_components.h3 id={toc[16].id}>{toc[16].value}</_components.h3>{"\n"}<_components.pre tabIndex="0" data-language="bash" data-word-wrap="" data-pagefind-ignore="all"><_components.code><_components.span><_components.span style={{
