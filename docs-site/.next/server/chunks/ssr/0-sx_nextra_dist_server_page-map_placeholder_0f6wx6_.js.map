mponents.tr><_components.tr><_components.td>{"9"}</_components.td><_components.td><_components.strong>{"reply"}</_components.strong></_components.td><_components.td>{"Sends a confirmation message (or error) to the reply topic"}</_components.td><_components.td>{"No reply topic in the inbound message"}</_components.td></_components.tr></_components.tbody></_components.table>{"\n"}<_components.p>{"Steps 3–6 are non-fatal: an error in one step is logged, and the pipeline continues to "}<_components.code>{"projects_yaml"}</_components.code>{". The pipeline aborts only if "}<_components.code>{"projects_yaml"}</_components.code>{" (step 7) fails."}</_components.p>{"\n"}<_components.hr />{"\n"}<_components.h2 id={toc[2].id}>{toc[2].value}</_components.h2>{"\n"}<_components.p>{"Sent as the "}<_components.code>{"payload"}</_components.code>{" of a "}<_components.code>{"message.inbound.onboard"}</_components.code>{" bus message (or the JSON body of "}<_components.code>{"POST /api/onboard"}</_components.code>{"):"}</_components.p>{"\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n"}<_components.table><_components.thead><_components.tr><_components.th>{"Field"}</_components.th><_components.th>{"Type"}</_components.th><_components.th>{"Required"}</_components.th><_components.th>{"Default"}</_components.th><_components.th>{"Description"}</_components.th></_components.tr></_components.thead><_components.tbody><_components.tr><_components.td><_components.code>{"slug"}</_components.code></_components.td><_components.td><_components.code>{"string"}</_components.code></_components.td><_components.td>{"✅"}</_components.td><_components.td>{"—"}</_components.td><_components.td>{"Unique project identifier, e.g. "}<_components.code>{"\"protolabsai-myproject\""}</_components.code></_components.td></_components.tr><_components.tr><_components.td><_components.code>{"title"}</_components.code></_components.td><_component