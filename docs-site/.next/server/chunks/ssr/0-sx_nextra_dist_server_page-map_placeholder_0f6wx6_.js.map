  }}>{": string[] }"}</_components.span></_components.span>{"\n"}<_components.span>{" "}</_components.span>{"\n"}<_components.span><_components.span style={{
    "--shiki-light": "#6A737D",
    "--shiki-dark": "#6A737D"
  }}>{"// Parse and validate the full projects.yaml structure (throws on invalid)"}</_components.span></_components.span>{"\n"}<_components.span><_components.span style={{
    "--shiki-light": "#6F42C1",
    "--shiki-dark": "#B392F0"
  }}>{"parseProjectsYaml"}</_components.span><_components.span style={{
    "--shiki-light": "#24292E",
    "--shiki-dark": "#E1E4E8"
  }}>{"(raw: unknown): ProjectsYaml"}</_components.span></_components.span></_components.code></_components.pre>{"\n"}<_components.hr />{"\n"}<_components.h2 id={toc[6].id}>{toc[6].value}</_components.h2>{"\n"}<_components.p>{"The pipeline is safe to re-run for the same project slug:"}</_components.p>{"\n"}<_components.ol>{"\n"}<_components.li><_components.strong>{"Step 2 (idempotency check)"}</_components.strong>{" exits early with "}<_components.code>{"status: \"already_onboarded\""}</_components.code>{" if the slug is already in "}<_components.code>{"projects.yaml"}</_components.code>{". No external API calls are made."}</_components.li>{"\n"}<_components.li><_components.strong>{"Step 5 (github_webhook)"}</_components.strong>{" lists existing webhooks before creating; skips if the target URL is already registered."}</_components.li>{"\n"}<_components.li><_components.strong>{"Step 7 (projects_yaml)"}</_components.strong>{" double-checks for the slug under a write lock before appending."}</_components.li>{"\n"}<_components.li><_components.strong>{"In-flight guard"}</_components.strong>{" — concurrent requests for the same slug are rejected with an error while the first run is in progress."}</_components.li>{"\n"}</_components.ol>{"\n"}<_components.hr />{"\n"}<_components.h2 id={toc[7].id}>{toc[7].value}</_components.h2>{"\n"}<_components.h3 id={toc[8].id}>{toc[8].value}</_components.h3>{"\n"}<_components.pre tabIndex="0" data-language="plaintext" data-word-wrap="" data-pagefind-ignore="all"><_components.code><_components.span><_components.span>{"message.inbound.onboard"}</_components.span></_components.span></_components.code></_components.pre>{"\n"}<_components.p>{"Any subscriber can publish to this topic to trigger onboarding. The payload must match the "}<_components.code>{"OnboardRequest"}</_components.code>{" schema above."}</_components.p>{"\n"}<_components.h3 id={toc[9].id}>{toc[9].value}</_components.h3>{"\n"}<_components.pre tabIndex="0" data-language="plaintext" data-word-wrap="" data-pagefind-ignore="all"><_components.code><_components.span><_components.span>{"POST /api/onboard"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"Content-Type: application/json"}</_components.span></_components.span>{"\n"}<_components.span><_components.span /></_components.span>{"\n"}<_components.span><_components.span>{"{"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"  \"slug\": \"protolabsai-myproject\","}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"  \"title\": \"My Project\","}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"  \"github\": \"protoLabsAI/my-project\""}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"}"}</_components.span></_components.span></_components.code></_components.pre>{"\n"}<_components.p>{"The HTTP handler waits up to 30 seconds for the pipeline to complete and returns the result synchronously. If the pipeline takes longer than 30s, it returns "}<_components.code>{"{ success: true, status: \"accepted\" }"}</_components.code>{" immediately and the pipeline continues in the background."}</_components.p>{"\n"}<_components.h3 id={toc[10].id}>{toc[10].value}</_components.h3>{"\n"}<_components.p>{"The Discord plugin routes slash commands to "}<_components.code>{"message.inbound.discord.slash.{interactionId}"}</_components.code>{" via the command config in "}<_components.code>{"workspace/discord.yaml"}</_components.code>{". An "}<_components.code>{"/onboard"}</_components.code>{" command configured in "}<_components.code>{"discord.yaml"}</_components.code>{" can pass the project fields as options and publish to "}<_components.code>{"message.inbound.onboard"}</_components.code>{". Autocomplete for project fields can be configured via the "}<_components.code>{"choices"}</_components.code>{" option in the command spec."}</_components.p>{"\n"}<_components.h3 id={toc[11].id}>{toc[11].value}</_components.h3>{"\n"}<_components.p>{"When the GitHub org webhook is registered and a new repository is created under the org, "}<_components.code>{"lib/plugins/github.ts"}</_components.code>{" catches the "}<_components.code>{"repository"}</_components.code>{" + "}<_components.code>{"action: created"}</_components.code>{" event and publishes to "}<_components.code>{"message.inbound.onboard"}</_components.code>{" automatically. The payload uses the repository’s "}<_components.code>{"full_name"}</_components.code>{", "}<_components.code>{"name"}</_components.code>{", "}<_components.code>{"owner.login"}</_components.code>{", "}<_components.code>{"description"}</_components.code>{", and visibility."}</_components.p>{"\n"}<_components.hr />{"\n"}<_components.h2 id={toc[12].id}>{toc[12].value}</_components.h2>{"\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n"}<_components.table><_components.thead><_components.tr><_components.th>{"Topic"}</_components.th><_components.th>{"When published"}</_components.th><_components.th>{"Payload highlights"}</_components.th></_components.tr></_components.thead><_components.tbody><_components.tr><_components.td><_components.code>{"message.inbound.onboard.complete"}</_components.code></_components.td><_components.td>{"After "}<_components.code>{"projects_yaml"}</_components.code>{" step succeeds"}</_components.td><_components.td><_components.code>{"slug"}</_components.code>{", "}<_components.code>{"github"}</_components.code>{", "}<_components.code>{"planeProjectId"}</_components.code>{", "}<_components.code>{"driveFolderId"}</_components.code>{", per-step "}<_components.code>{"status"}</_components.code></_components.td></_components.tr><_components.tr><_components.td><_components.code>{"{msg.reply.topic}"}</_components.code></_components.td><_components.td>{"After pipeline finishes (success or error)"}</_components.td><_components.td>{"Full result with "}<_components.code>{"success"}</_components.code>{", "}<_components.code>{"step"}</_components.code>{", human-readable "}<_components.code>{"content"}</_components.code></_components.td></_components.tr></_components.tbody></_components.table>{"\n"}<_components.hr />{"\n"}<_components.h2 id={toc[13].id}>{toc[13].value}</_components.h2>{"\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n"}<_components.table><_components.thead><_components.tr><_components.th>{"Variable"}</_components.th><_components.th>{"Required by"}</_components.th><_components.th>{"Default"}</_components.th><_components.th>{"Purpose"}</_components.th></_components.tr></_components.thead><_components.tbody><_components.tr><_components.td><_components.code>{"PLANE_API_KEY"}</_components.code></_components.td><_components.td>{"Steps 3, 4"}</_components.td><_components.td>{"—"}</_components.td><_components.td>{"Enables Plane project and webhook creation"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"PLANE_BASE_URL"}</_components.code></_components.td><_components.td>{"Steps 3, 4"}</_components.td><_components.td><_components.code>{"http://ava:3002"}</_components.code></_components.td><_components.td>{"Plane instance URL"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"PLANE_WORKSPACE_SLUG"}</_components.code></_components.td><_components.td>{"Steps 3, 4"}</_components.td><_components.td><_components.code>{"protolabsai"}</_components.code></_components.td><_components.td>{"Plane workspace slug"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"PLANE_WEBHOOK_SECRET"}</_components.code></_components.td><_components.td>{"Step 4"}</_components.td><_components.td>{"—"}</_components.td><_components.td>{"Optional HMAC secret for Plane webhooks"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"WORKSTACEAN_PUBLIC_URL"}</_components.code></_components.td><_components.td>{"Steps 4, 5"}</_components.td><_components.td>{"—"}</_components.td><_components.td>{"Base URL for webhook registration (e.g. "}<_components.code>{"https://ws.example.com"}</_components.code>{")"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"QUINN_APP_ID"}</_components.code></_components.td><_components.td>{"Step 5"}</_components.td><_components.td>{"—"}</_components.td><_components.td>{"GitHub App ID for auth (used by "}<_components.code>{"makeGitHubAuth"}</_components.code>{")"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"QUINN_APP_PRIVATE_KEY"}</_components.code></_components.td><_components.td>{"Step 5"}</_components.td><_components.td>{"—"}</_components.td><_components.td>{"GitHub App private key"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"GITHUB_TOKEN"}</_components.code></_components.td><_components.td>{"Step 5"}</_components.td><_components.td>{"—"}</_components.td><_components.td>{"Alternative GitHub PAT for webhook registration"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"GITHUB_WEBHOOK_SECRET"}</_components.code></_components.td><_components.td>{"Step 5"}</_components.td><_components.td>{"—"}</_components.td><_components.td>{"Optional HMAC secret for GitHub webhooks"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"GOOGLE_CLIENT_ID"}</_components.code></_components.td><_components.td>{"Step 6"}</_components.td><_components.td>{"—"}</_components.td><_components.td>{"Google OAuth client ID"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"GOOGLE_CLIENT_SECRET"}</_components.code></_components.td><_components.td>{"Step 6"}</_components.td><_components.td>{"—"}</_components.td><_components.td>{"Google OAuth client secret"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"GOOGLE_REFRESH_TOKEN"}</_components.code></_components.td><_components.td>{"Step 6"}</_components.td><_components.td>{"—"}</_components.td><_components.td>{"Google OAuth refresh token"}</_components.td></_components.tr></_components.tbody></_components.table>{"\n"}<_components.hr />{"\n"}<_components.h2 id={toc[14].id}>{toc[14].value}</_components.h2>{"\n"}<_components.p>{"The following workspace config files are watched at runtime (polled every 5 seconds by Node’s "}<_components.code>{"watchFile"}</_components.code>{"). Changes take effect without a container restart:"}</_components.p>{"\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n"}<_components.table><_components.thead><_components.tr><_components.th>{"File"}</_components.th><_components.th>{"Watched by"}</_components.th><_components.th>{"What reloads"}</_components.th></_components.tr></_components.thead><_components.tbody><_components.tr><_components.td><_components.code>{"workspace/github.yaml"}</_components.code></_components.td><_components.td><_components.code>{"GithubPlugin"}</_components.code></_components.td><_components.td>{"Monitored repos, org webhook config, mention handle, auto-triage settings"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"workspace/projects.yaml"}</_components.code></_components.td><_components.td><_components.code>{"GithubPlugin"}</_components.code>{", "}<_components.code>{"A2aPlugin"}</_components.code></_components.td><_components.td>{"Monitored repo list (GithubPlugin), project routing table (A2aPlugin)"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"workspace/discord.yaml"}</_components.code></_components.td><_components.td><_components.code>{"DiscordPlugin"}</_components.code></_components.td><_components.td>{"Channel config, slash command list (re-registers commands on change)"}</_components.td></_components.tr><_componen