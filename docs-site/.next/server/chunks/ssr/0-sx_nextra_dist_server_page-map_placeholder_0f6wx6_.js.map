  }}>{"});"}</_components.span></_components.span></_components.code></_components.pre>{"\n"}<_components.p>{"After "}<_components.code>{"pi.registerTool()"}</_components.code>{" returns, the tool is immediately callable by the LLM in the current session."}</_components.p>{"\n"}<_components.h3 id={toc[8].id}>{toc[8].value}</_components.h3>{"\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n"}<_components.table><_components.thead><_components.tr><_components.th>{"Path"}</_components.th><_components.th>{"Scope"}</_components.th></_components.tr></_components.thead><_components.tbody><_components.tr><_components.td><_components.code>{"~/.pi/agent/extensions/*.ts"}</_components.code></_components.td><_components.td>{"Global — loaded for all projects"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{".pi/extensions/*.ts"}</_components.code></_components.td><_components.td>{"Project-local — loaded only in this project"}</_components.td></_components.tr></_components.tbody></_components.table>{"\n"}<_components.p>{"Extensions in "}<_components.code>{".pi/extensions/"}</_components.code>{" are tied to the project directory. When the agent starts in the protoWorkstacean workspace, all extensions in this directory are loaded."}</_components.p>{"\n"}<_components.h3 id={toc[9].id}>{toc[9].value}</_components.h3>{"\n"}<_components.p>{"Extensions can subscribe to lifecycle events:"}</_components.p>{"\n"}<_components.ul>{"\n"}<_components.li><_components.code>{"session_start"}</_components.code>{" — fires when an agent session begins"}</_components.li>{"\n"}<_components.li><_components.code>{"session_end"}</_components.code>{" — fires when a session ends"}</_components.li>{"\n"}<_components.li><_components.code>{"tool_call"}</_components.code>{" — fires before each tool call (can intercept/block)"}</_components.li>{"\n"}<_components.li><_components.code>{"agent_turn"}</_components.code>{" — fires after each agent response"}</_components.li>{"\n"}</_components.ul>{"\n"}<_components.p>{"These enable patterns like injecting context at session start, logging tool calls, or implementing dynamic tool enable/disable based on project state."}</_components.p>{"\n"}<_components.hr />{"\n"}<_components.h2 id={toc[10].id}>{toc[10].value}</_components.h2>{"\n"}<_components.p>{"The SchedulerPlugin has its own internal lifecycle for timers:"}</_components.p>{"\n"}<_components.ol>{"\n"}<_components.li>{"On "}<_components.code>{"install()"}</_components.code>{", it scans "}<_components.code>{"data/crons/"}</_components.code>{" for YAML files and creates Node.js timers for each enabled schedule"}</_components.li>{"\n"}<_components.li>{"On "}<_components.code>{"command.schedule"}</_components.code>{" action "}<_components.code>{"add"}</_components.code>{" — creates a timer immediately and writes the YAML file"}</_components.li>{"\n"}<_components.li>{"On "}<_components.code>{"command.schedule"}</_components.code>{" action "}<_components.code>{"remove"}</_components.code>{" — cancels the timer and deletes the YAML file"}</_components.li>{"\n"}<_components.li>{"On "}<_components.code>{"command.schedule"}</_components.code>{" action "}<_components.code>{"pause/resume"}</_components.code>{" — cancels/recreates the timer; updates "}<_components.code>{"enabled"}</_components.code>{" in the YAML"}</_components.li>{"\n"}<_components.li>{"On "}<_components.code>{"uninstall()"}</_components.code>{" — cancels all active timers"}</_components.li>{"\n"}</_components.ol>{"\n"}<_components.p><_components.strong>{"Missed fire recovery"}</_components.strong>{": On startup, after loading all schedules, the plugin checks each "}<_components.code>{"lastFired"}</_components.code>{" timestamp. If a schedule was due between "}<_components.code>{"lastFired"}</_components.code>{" and now:"}</_components.p>{"\n"}<_components.ul>{"\n"}<_components.li>{"Missed by ≤ 24 hours → fires immediately once"}</_components.li>{"\n"}<_components.li>{"Missed by > 24 hours → skipped; next regular fire applies"}</_components.li>{"\n"}</_components.ul>{"\n"}<_components.hr />{"\n"}<_components.h2 id={toc[11].id}>{toc[11].value}</_components.h2>{"\n"}<_components.p>{"Workspace bus plugins use Node.js dynamic imports ("}<_components.code>{"import()"}</_components.code>{"). The Node module loader caches imports. Replacing a cached module requires restarting the process — there is no safe way to hot-reload a module in a running Node/Bun process without risking stale closure references."}</_components.p>{"\n"}<_components.p>{"Pi SDK extensions bypass this by using the Pi SDK’s own extension runtime, which has first-class support for dynamic tool registration via "}<_components.code>{"pi.registerTool()"}</_components.code>{". The Pi SDK is designed for interactive use where adding tools at runtime is a core feature."}</_components.p>{"\n"}<_components.p>{"The two systems are complementary: use Pi SDK extensions when you need immediate availability without restart; use workspace plugins when you need to bridge external services at the transport layer (HTTP servers, gateway connections, polling loops)."}</_components.p>{"\n"}<_components.hr />{"\n"}<_components.h2 id={toc[12].id}>{toc[12].value}</_components.h2>{"\n"}<_components.p>{"If a workspace plugin file fails to import (syntax error, missing dependency), "}<_components.code>{"loadWorkspacePlugins()"}</_components.code>{" logs the error and skips that plugin. Other plugins continue to load. The server starts regardless."}</_components.p>{"\n"}<_components.p>{"If a plugin’s "}<_components.code>{"install()"}</_components.code>{" throws, the error is caught and logged. The plugin is not installed, but the server continues."}</_components.p>{"\n"}<_components.p>{"This means a broken plugin in "}<_components.code>{"workspace/plugins/"}</_components.code>{" never prevents the server from starting — you can always connect and debug."}</_components.p></>;
}
export default _createMdxContent;
