  }}>{"print"}</_components.span><_components.span style={{
    "--shiki-light": "#24292E",
    "--shiki-dark": "#E1E4E8"
  }}>{"(wh.secret_key)  "}</_components.span><_components.span style={{
    "--shiki-light": "#6A737D",
    "--shiki-dark": "#6A737D"
  }}>{"# copy this — store as PLANE_WEBHOOK_SECRET"}</_components.span></_components.span></_components.code></_components.pre>{"\n"}<_components.p>{"The "}<_components.code>{"secret_key"}</_components.code>{" printed by the ORM is the HMAC secret. Store it immediately — you cannot retrieve it again after the shell session."}</_components.p>{"\n"}<_components.h3 id={toc[3].id}>{toc[3].value}</_components.h3>{"\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n"}<_components.table><_components.thead><_components.tr><_components.th>{"Path prefix"}</_components.th><_components.th>{"Auth method"}</_components.th><_components.th>{"Works for"}</_components.th></_components.tr></_components.thead><_components.tbody><_components.tr><_components.td><_components.code>{"/api/v1/workspaces/..."}</_components.code></_components.td><_components.td>{"API key ("}<_components.code>{"X-Api-Key"}</_components.code>{" header)"}</_components.td><_components.td>{"Issues, states, projects, members"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"/api/workspaces/..."}</_components.code></_components.td><_components.td>{"Session cookie only"}</_components.td><_components.td>{"Webhooks, some admin paths"}</_components.td></_components.tr></_components.tbody></_components.table>{"\n"}<_components.p>{"If you hit a 401 on "}<_components.code>{"/api/workspaces/..."}</_components.code>{" with a valid API key, this is a Django REST Framework routing bug — the path is not registered under the API-key-authenticated router at all. Switch to the Django ORM approach."}</_components.p>{"\n"}<_components.h2 id={toc[4].id}>{toc[4].value}</_components.h2>{"\n"}<_components.p>{"The "}<_components.code>{"PlanePlugin"}</_components.code>{" ("}<_components.code>{"lib/plugins/plane.ts"}</_components.code>{") filters inbound webhook events by label:"}</_components.p>{"\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n"}<_components.table><_components.thead><_components.tr><_components.th>{"Label"}</_components.th><_components.th>{"Behaviour"}</_components.th></_components.tr></_components.thead><_components.tbody><_components.tr><_components.td><_components.code>{"plan"}</_components.code></_components.td><_components.td>{"Routes to Ava via bus, requires HITL approval before features are created"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"auto"}</_components.code></_components.td><_components.td>{"Routes to Ava via bus, skips HITL gate entirely — features created immediately"}</_components.td></_components.tr><_components.tr><_components.td>{"(anything else)"}</_components.td><_components.td>{"Silently dropped"}</_components.td></_components.tr></_components.tbody></_components.table>{"\n"}<_components.p>{"Only "}<_components.code>{"issue"}</_components.code>{" events (create/update/delete) are subscribed. Project/cycle/module events are ignored."}</_components.p>{"\n"}<_components.h2 id={toc[5].id}>{toc[5].value}</_components.h2>{"\n"}<_components.pre tabIndex="0" data-language="plaintext" data-word-wrap="" data-pagefind-ignore="all"><_components.code><_components.span><_components.span>{"1. Plane issue created/updated with \"plan\" or \"auto\" label"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"2. POST /webhooks/plane (port 8083 on workstacean container)"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"3. PlanePlugin:"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"   a. Verify HMAC-SHA256 signature against PLANE_WEBHOOK_SECRET"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"      → 401 if invalid"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"   b. Check X-Plane-Delivery UUID against 10k-entry deduplication ring"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"      → silent drop if already seen"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"   c. Check issue labels for \"plan\" or \"auto\""}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"      → silent drop if neither label present"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"   d. Extract planeIssueId and planeProjectId"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"   e. Publish to bus:"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"      topic:     message.inbound.plane.issue.create"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"      skillHint: \"plan\""}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"      correlationId: plane-{issueId}"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"   f. Store {planeIssueId, planeProjectId} in pendingIssues Map keyed by correlationId"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"4. A2APlugin routes to Ava (skillHint \"plan\" → plan skill)"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"5. Ava runs SPARC PRD + antagonistic review (Ava operational lens + Jon strategic lens)"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"6. HITL gate:"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"   - \"auto\" label → skip gate, emit HITLResponse(approve) internally"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"   - \"plan\" label → emit HITLRequest to plane.reply.{correlationId}"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"7. On approval: Ava's plan_resume creates board features, stamps correlationId"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"8. PlanePlugin outbound handler picks up plane.reply.# events → syncs back to Plane"}</_components.span></_components.span></_components.code></_components.pre>{"\n"}<_components.h2 id={toc[6].id}>{toc[6].value}</_components.h2>{"\n"}<_components.p>{"After a plan is approved and features are created, the "}<_components.code>{"PlanePlugin"}</_components.code>{" outbound handler subscribes to "}<_components.code>{"plane.reply.#"}</_components.code>{" and performs two API calls against "}<_components.code>{"PLANE_BASE_URL"}</_components.code>{" ("}<_components.code>{"http://ava:3002"}</_components.code>{"):"}</_components.p>{"\n"}<_components.ol>{"\n"}<_components.li><_components.strong>{"PATCH issue state"}</_components.strong>{": sets the issue to “In Progress” when a plan is approved; sets it to “Done” when the plan completes (all features created)."}</_components.li>{"\n"}<_components.li><_components.strong>{"POST comment"}</_components.strong>{": posts a summary comment to the issue with a brief description of what was planned and which features were created."}</_components.li>{"\n"}</_components.ol>{"\n"}<_components.h3 id={toc[7].id}>{toc[7].value}</_components.h3>{"\n"}<_components.p>{"A2A replies don’t carry Plane metadata — they only carry "}<_components.code>{"correlationId"}</_components.code>{". When the "}<_components.code>{"PlanePlugin"}</_components.code>{" first publishes an event it stores "}<_components.code>{"{planeIssueId, planeProjectId}"}</_components.code>{" in a "}<_components.code>{"pendingIssues"}</_components.code>{" Map keyed by "}<_components.code>{"correlationId"}</_components.code>{" (format: "}<_components.code>{"plane-{issueId}"}</_components.code>{"). The outbound handler looks up this map to reconstruct the API call targets. The map is in-memory and not persisted; a workstacean restart clears it, which means in-flight approvals would lose their sync-back path (the board features still get created; only the Plane state update is lost)."}</_components.p>{"\n"}<_components.h2 id={toc[8].id}>{toc[8].value}</_components.h2>{"\n"}<_components.p>{"All secrets live in Infisical. Two projects hold Plane-related secrets:"}</_components.p>{"\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n"}<_components.table><_components.thead><_components.tr><_components.th>{"Secret"}</_components.th><_components.th>{"Infisical Project"}</_components.th><_components.th>{"Notes"}</_components.th></_components.tr></_components.thead><_components.tbody><_components.tr><_components.td><_components.code>{"PLANE_WEBHOOK_SECRET"}</_components.code></_components.td><_components.td>{"AI project ("}<_components.code>{"11e172e0"}</_components.code>{") and homelab project"}</_components.td><_components.td>{"HMAC key from Django ORM creation step"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"PLANE_API_KEY"}</_components.code></_components.td><_components.td>{"AI project ("}<_components.code>{"11e172e0"}</_components.code>{")"}</_components.td><_components.td>{"For "}<_components.code>{"/api/v1/"}</_components.code>{" reads and writes"}</_components.td></_components.tr></_components.tbody></_components.table>{"\n"}<_components.p>{"Workstacean env vars (set via "}<_components.code>{"infisical run"}</_components.code>{"):"}</_components.p>{"\n"}<_components.pre tabIndex="0" data-language="plaintext" data-word-wrap="" data-pagefind-ignore="all"><_components.code><_components.span><_components.span>{"PLANE_WEBHOOK_SECRET   — HMAC validation for incoming webhooks"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"PLANE_API_KEY          — outbound API calls to Plane"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"PLANE_BASE_URL         — defaults to http://ava:3002"}</_components.span></_components.span>{"\n"}<_components.span><_components.span>{"PLANE_WORKSPACE_SLUG   — defaults to protolabsai"}</_components.span></_components.span></_components.code></_components.pre>{"\n"}<_components.p>{"These are declared in "}<_components.code>{"stacks/ai/docker-compose.yml"}</_components.code>{" in the homelab-iac repo under the "}<_components.code>{"workstacean"}</_components.code>{" service."}</_components.p>{"\n"}<_components.h2 id={toc[9].id}>{toc[9].value}</_components.h2>{"\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n"}<_components.table><_components.thead><_components.tr><_components.th>{"Topic"}</_components.th><_components.th>{"Direction"}</_components.th><_components.th>{"Description"}</_components.th></_components.tr></_components.thead><_components.tbody><_components.tr><_components.td><_components.code>{"message.inbound.plane.issue.create"}</_components.code></_components.td><_components.td>{"Published (inbound)"}</_components.td><_components.td>{"New issue event with "}<_components.code>{"skillHint: \"plan\""}</_components.code></_components.td></_components.tr><_components.tr><_components.td><_components.code>{"message.inbound.plane.issue.update"}</_components.code></_components.td><_components.td>{"Published (inbound)"}</_components.td><_components.td>{"Update event (currently not routed)"}</_components.td></_components.tr><_components.tr><_components.td><_components.code>{"plane.reply.{issueId}"}</_components.code></_components.td><_components.td>{"Subscribed (outbound)"}</_components.td><_components.td>{"A2A reply — triggers state PATCH + comment"}</_components.td></_components.tr></_components.tbody></_components.table>{"\n"}<_components.h2 id={toc[10].id}>{toc[10].value}</_components.h2>{"\n"}<_components.p>{"The inbound message published to "}<_components.code>{"message.inbound.plane.issue.create"}</_components.code>{":"}</_components.p>{"\n"}<_components.pre tabIndex="0" data-language="ts" data-word-wrap="" data-pagefind-ignore="all"><_components.code><_components.span><_components.span style={{
