5:["$","div",null,{"className":"x:mx-auto x:flex x:max-w-(--nextra-content-width)","children":["$","$L1f",null,{"value":[{"value":"1. Overview","id":"1-overview","depth":2},{"value":"2. Message Types","id":"2-message-types","depth":2},{"value":"HITLRequest","id":"hitlrequest","depth":3},{"value":"HITLResponse","id":"hitlresponse","depth":3},{"value":"3. Plugin Architecture","id":"3-plugin-architecture","depth":2},{"value":"4. Plan Flow","id":"4-plan-flow","depth":2},{"value":"plan skill (fire-and-forget)","id":"plan-skill-fire-and-forget","depth":3},{"value":"plan_resume skill","id":"plan_resume-skill","depth":3},{"value":"5. Decision Paths","id":"5-decision-paths","depth":2},{"value":"6. Auto-Approve","id":"6-auto-approve","depth":2},{"value":"7. Expiry","id":"7-expiry","depth":2},{"value":"8. correlationId Conventions","id":"8-correlationid-conventions","depth":2},{"value":"9. Bus Topics","id":"9-bus-topics","depth":2},{"value":"10. Interface Rendering","id":"10-interface-rendering","depth":2},{"value":"Discord","id":"discord","depth":3},{"value":"Plane reply","id":"plane-reply","depth":3},{"value":"API polling","id":"api-polling","depth":3},{"value":"Adding a new renderer","id":"adding-a-new-renderer","depth":3},{"value":"11. Pending Request Lifecycle","id":"11-pending-request-lifecycle","depth":2},{"value":"12. plan_resume A2A Call","id":"12-plan_resume-a2a-call","depth":2},{"value":"13. Design Principle","id":"13-design-principle","depth":2},{"value":"14. Testing","id":"14-testing","depth":2},{"value":"Simulate an approval without a real Plane issue","id":"simulate-an-approval-without-a-real-plane-issue","depth":3},{"value":"Simulate a modify round","id":"simulate-a-modify-round","depth":3},{"value":"Simulate a rejection","id":"simulate-a-rejection","depth":3},{"value":"Verify PlanStore checkpoint","id":"verify-planstore-checkpoint","depth":3}],"children":[["$","$L20",null,{}],["$","$L21",null,{"metadata":{"title":"HITL — Human-in-the-Loop Gate","filePath":"../docs/guides/hitl.md"},"bottomContent":"$undefined","sourceCode":"$undefined","children":[["$","div",null,{"id":"nextra-skip-nav"}],["$","main",null,{"data-pagefind-body":true,"children":[["$","h1",null,{"id":"$undefined","className":"x:tracking-tight x:text-slate-900 x:dark:text-slate-100 x:font-bold x:mt-2 x:text-4xl","children":["HITL — Human-in-the-Loop Gate","$undefined"]}],"\n",["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":"HITL is the approval gate that sits between Ava generating a SPARC PRD and features landing on the board. It exists because autonomous project creation has permanent side effects: board features, Plane state changes, Discord channel provisioning. The gate gives a human (or a trusted automated signal) the chance to approve, reject, or modify a plan before any of that happens."}],"\n",["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":[["$","code",null,{"className":"nextra-code","dir":"ltr","children":"correlationId"}]," is the spine that connects every hop."]}],"\n",["$","h2",null,{"id":"1-overview","className":"x:tracking-tight x:text-slate-900 x:dark:text-slate-100 x:font-semibold x:target:animate-[fade-in_1.5s] x:mt-10 x:border-b x:pb-1 x:text-3xl nextra-border","children":["1. Overview",["$","$L22",null,{"id":"1-overview"}]]}],"\n",["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":["When Ava completes the ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"plan"}]," skill, it returns immediately with ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"{ status: \"pending_approval\", correlationId }"}]," rather than blocking. The plan state (PRD + review scores + metadata) is checkpointed to SQLite (",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"plans.db"}],", 7-day TTL). An ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"HITLRequest"}]," is published to the bus, which routes it to the originating interface plugin for native rendering. A human responds, the interface plugin publishes an ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"HITLResponse"}],", and Workstacean routes to Ava’s ","$L23"," skill to complete the flow."]}],"\n","$L24","\n","$L25","\n","$L26","\n","$L27","\n","$L28","\n","$L29","\n","$L2a","\n","$L2b","\n","$L2c","\n","$L2d","\n","$L2e","\n","$L2f","\n","$L30","\n","$L31","\n","$L32","\n","$L33","\n","$L34","\n","$L35","\n","$L36","\n","$L37","\n","$L38","\n","$L39","\n","$L3a","\n","$L3b","\n","$L3c","\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n","$L3d","\n","$L3e","\n","$L3f","\n","$L40","\n","$L41","\n","$L42","\n","$L43","\n","$L44","\n","$L45","\n","$L46","\n","$L47","\n","$L48","\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n","$L49","\n","$L4a","\n","$L4b","\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n","$L4c","\n","$L4d","\n","$L4e","\n","$L4f","\n","$L50","\n","$L51","\n","$L52","\n","$L53","\n","$L54","\n","$L55","\n","$L56","\n","$L57","\n","$L58","\n","$L59","\n","$L5a","\n","$L5b","\n","$L5c","\n","$L5d","\n","$L5e","\n","$L5f","\n","$L60","\n","$L61","\n","$L62","\n","$L63","\n","$L64","\n","$L65","\n","$L66","\n","$L67","\n","$L68","\n","$L69","\n","$L6a","\n","$L6b"]}]]}]]}]}]
