3d:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":"The L1 planner uses the A* search algorithm to find a least-cost plan through an action graph."}]
3e:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":[["$","em",null,{"children":[["$","em",null,{"children":"How A"}]," works here:"]}],"*"]}]
3f:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":"Each node in the search graph represents a possible world state. Each edge represents an action — with a precondition (when can this action be taken?) and an effect (what state change does it produce?). The planner starts at the current world state and searches for a path to a state that satisfies the goal predicate."}]
40:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":"A* uses two scores per node:"}]
41:["$","ul",null,{"className":"x:[:is(ol,ul)_&]:my-[.75em] x:not-first:mt-[1.25em] x:list-disc x:ms-[1.5em]","children":["\n",["$","li",null,{"className":"x:my-[.5em]","children":[["$","code",null,{"className":"nextra-code","dir":"ltr","children":"g(n)"}]," — actual cost to reach node ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"n"}]," from the start (sum of action costs along the path)"]}],"\n",["$","li",null,{"className":"x:my-[.5em]","children":[["$","code",null,{"className":"nextra-code","dir":"ltr","children":"h(n)"}]," — heuristic estimate of remaining cost to reach the goal from ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"n"}]]}],"\n",["$","li",null,{"className":"x:my-[.5em]","children":[["$","code",null,{"className":"nextra-code","dir":"ltr","children":"f(n) = g(n) + h(n)"}]," — total estimated cost"]}],"\n"]}]
42:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":["The search always expands the node with the lowest ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"f"}]," score. This guarantees it finds the optimal (least-cost) plan when the heuristic is admissible (never overestimates the true remaining cost)."]}]
