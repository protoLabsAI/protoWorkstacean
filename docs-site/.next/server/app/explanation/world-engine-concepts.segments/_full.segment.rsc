30:["$","h2",null,{"id":"why-4-escalation-tiers","className":"x:tracking-tight x:text-slate-900 x:dark:text-slate-100 x:font-semibold x:target:animate-[fade-in_1.5s] x:mt-10 x:border-b x:pb-1 x:text-3xl nextra-border","children":["Why 4 escalation tiers?",["$","$L22",null,{"id":"why-4-escalation-tiers"}]]}]
31:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":["The four-tier ladder (L0 → L1 → L2 → Human) reflects a fundamental trade-off: ",["$","strong",null,{"children":"cost vs. capability"}],"."]}]
32:["$","div",null,{"data-pagefind-ignore":"all","className":"nextra-code x:relative x:not-first:mt-[1.25em]","children":["$undefined",["$","pre",null,{"className":"x:group x:focus-visible:nextra-focus x:overflow-x-auto x:subpixel-antialiased x:text-[.9em] x:bg-white x:dark:bg-black x:py-4 x:ring-1 x:ring-inset x:ring-gray-300 x:dark:ring-neutral-700 x:contrast-more:ring-gray-900 x:contrast-more:dark:ring-gray-50 x:contrast-more:contrast-150 x:rounded-md not-prose","tabIndex":"0","children":[["$","div",null,{"className":"x:group-hover:opacity-100 x:group-focus:opacity-100 x:opacity-0 x:transition x:focus-within:opacity-100 x:flex x:gap-1 x:absolute x:right-4 x:top-2","children":[["$","$L5a",null,{"children":["$","svg",null,{"viewBox":"0 0 24 24","fill":"currentColor","height":"1em","children":["$","path",null,{"d":"M4 19h6v-2H4v2zM20 5H4v2h16V5zm-3 6H4v2h13.25c1.1 0 2 .9 2 2s-.9 2-2 2H15v-2l-3 3l3 3v-2h2c2.21 0 4-1.79 4-4s-1.79-4-4-4z"}]}]}],false]}],["$","code",null,{"className":"nextra-code","dir":"ltr","children":[["$","span",null,{"children":["$","span",null,{"children":"Cost (and capability)"}]}],"\n",["$","span",null,{"children":["$","span",null,{"children":"▲"}]}],"\n",["$","span",null,{"children":["$","span",null,{"children":"│   Human         expensive, most capable, unlimited judgment"}]}],"\n",["$","span",null,{"children":["$","span",null,{"children":"│   Ava (L2)      moderate cost, flexible LLM reasoning"}]}],"\n",["$","span",null,{"children":["$","span",null,{"children":"│   A* planner    cheap, systematic but bounded"}]}],"\n",["$","span",null,{"children":["$","span",null,{"children":"│   Rule matcher  free, instant, but rigid"}]}],"\n",["$","span",null,{"children":["$","span",null,{"children":"└────────────────────────────────────► Situations handled"}]}]]}]]}]]}]
33:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":[["$","strong",null,{"children":"L0 (deterministic rules)"}]," costs nothing. A rule like “if auth is down, restart it” runs in microseconds with no LLM call. It works perfectly for situations that have been seen before and have a known fix. The limitation is brittleness — rules only fire when conditions exactly match."]}]
34:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":[["$","em",null,{"children":[["$","em",null,{"children":"L1 (A"}]," planner)"]}],"* costs very little. A planning call to a cheap model is orders of magnitude less expensive than a full Ava session. The planner can handle novel combinations of actions and goals — it doesn’t need a pre-written rule for every situation. It is still bounded: it only knows actions in its action graph, and it runs within a time budget."]}]
35:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":[["$","strong",null,{"children":"L2 (Ava, LLM reasoning)"}]," handles situations the planner cannot. Ava can reason about ambiguous goals, weigh trade-offs not captured in action costs, ask clarifying questions, and compose actions in ways not represented in the graph. This flexibility comes at a cost — an Ava session is measurably more expensive than a planning call."]}]
36:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":[["$","strong",null,{"children":"L3 (human)"}]," is the failsafe for situations that exceed the system’s authority or capability. Some decisions should not be automated: large expenditures, irreversible actions, policy violations, genuinely novel incidents. The 30-minute HITL approval window gives humans the decision without making them a bottleneck for routine work."]}]
37:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":"The tier assignment is automatic, driven by two inputs:"}]
38:["$","ul",null,{"className":"x:[:is(ol,ul)_&]:my-[.75em] x:not-first:mt-[1.25em] x:list-disc x:ms-[1.5em]","children":["\n",["$","li",null,{"className":"x:my-[.5em]","children":[["$","strong",null,{"children":"Estimated cost"}]," of the request"]}],"\n",["$","li",null,{"className":"x:my-[.5em]","children":[["$","strong",null,{"children":"Remaining budget ratio"}]," (project and daily)"]}],"\n"]}]
39:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":"This ensures the system degrades gracefully as budgets deplete: a request that would be L0 early in the day escalates to L1 or L2 as the budget is consumed."}]
3a:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":["The target is ",["$","strong",null,{"children":"85–90% autonomous rate"}]," — meaning ≤ 10–15% of requests reach L2 or higher. If the autonomous rate falls below this, ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"BudgetPlugin"}]," fires an ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"ops.alert.budget"}]," event."]}]
3b:["$","hr",null,{"className":"x:my-[2em] nextra-border"}]
