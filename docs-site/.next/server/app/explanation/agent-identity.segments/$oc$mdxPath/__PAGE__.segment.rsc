1e:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":["All per-agent secrets live in Infisical (AI project ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"11e172e0"}],"). The workstacean container receives them via ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"infisical run"}]," at deploy time. The homelab-iac ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"docker-compose.yml"}]," is the canonical reference for which secrets map to which services."]}]
