f:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":[["$","code",null,{"className":"nextra-code","dir":"ltr","children":"WorldStateEngine.registerDomain(name, collector, tickMs)"}]," is the only API. A collector is any function ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"() => Promise<unknown>"}],". The world engine doesn’t care what the collector does — it polls it, stores the result under ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"domains.<name>.data"}],", and publishes ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"world.state.updated"}],"."]}]
10:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":[["$","code",null,{"className":"nextra-code","dir":"ltr","children":"createHttpCollector(url, opts)"}]," is a factory for the common case of polling an HTTP endpoint. But because the collector is a plain function, you can register:"]}]
11:["$","ul",null,{"className":"x:[:is(ol,ul)_&]:my-[.75em] x:not-first:mt-[1.25em] x:list-disc x:ms-[1.5em]","children":["\n",["$","li",null,{"className":"x:my-[.5em]","children":"Mock collectors for testing"}],"\n",["$","li",null,{"className":"x:my-[.5em]","children":"Collectors that read from files"}],"\n",["$","li",null,{"className":"x:my-[.5em]","children":"Collectors that aggregate multiple endpoints"}],"\n",["$","li",null,{"className":"x:my-[.5em]","children":"Collectors that compute derived data from other domains"}],"\n"]}]
12:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":["This is not a currently documented extension point, but the architecture supports it cleanly because the world engine depends on the ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"() => Promise<unknown>"}]," interface, not on HTTP."]}]
