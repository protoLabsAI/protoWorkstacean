35:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":"The GOAP (Goal-Oriented Action Planning) loop runs continuously alongside domain polling:"}]
36:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":[["$","strong",null,{"children":"WorldStateEngine"}]," fires ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"world.state.updated"}]," after every domain poll."]}]
37:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":[["$","strong",null,{"children":"GoalEvaluatorPlugin"}]," subscribes to ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"world.state.updated"}],". For each updated domain, it evaluates all loaded goals:"]}]
38:["$","ul",null,{"className":"x:[:is(ol,ul)_&]:my-[.75em] x:not-first:mt-[1.25em] x:list-disc x:ms-[1.5em]","children":["\n",["$","li",null,{"className":"x:my-[.5em]","children":[["$","code",null,{"className":"nextra-code","dir":"ltr","children":"Threshold"}]," goals: checks ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"value < min || value > max"}]]}],"\n",["$","li",null,{"className":"x:my-[.5em]","children":[["$","code",null,{"className":"nextra-code","dir":"ltr","children":"Invariant"}]," goals: checks boolean operator against a world-state value"]}],"\n",["$","li",null,{"className":"x:my-[.5em]","children":[["$","code",null,{"className":"nextra-code","dir":"ltr","children":"Distribution"}]," goals: checks proportions against target distributions within tolerance"]}],"\n"]}]
39:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":["When a goal is violated, it emits ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"world.goal.violated"}]," with the goal ID, severity, and the current world-state snapshot."]}]
3a:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":[["$","strong",null,{"children":"PlannerPluginL0"}]," subscribes to ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"world.goal.violated"}],". It queries ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"ActionRegistry"}]," for actions whose ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"goalId"}]," matches the violated goal and whose ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"preconditions"}]," are satisfied against the current world state. It packages the selected actions into a ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"world.action.plan"}]," message."]}]
3b:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":[["$","strong",null,{"children":"ActionDispatcherPlugin"}]," subscribes to ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"world.action.plan"}],". It fires each action by publishing to ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"action.meta.topic"}],", subject to a WIP (work-in-progress) limit to prevent runaway firing."]}]
3c:["$","h2",null,{"id":"why-tier_0-vs-tier_1-vs-tier_2","className":"x:tracking-tight x:text-slate-900 x:dark:text-slate-100 x:font-semibold x:target:animate-[fade-in_1.5s] x:mt-10 x:border-b x:pb-1 x:text-3xl nextra-border","children":["Why tier_0 vs tier_1 vs tier_2",["$","$L22",null,{"id":"why-tier_0-vs-tier_1-vs-tier_2"}]]}]
3d:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":"Tier_0 actions are deterministic and cheap: send an alert, trigger a ceremony. They require no planning — if the preconditions are met, fire immediately."}]
3e:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":["Tier_1 actions require A*-based sequencing. When multiple goals are violated simultaneously, the planner needs to reason about which combination of actions resolves them efficiently. The ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"cost"}]," field and ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"effects"}]," array are used by the planner to simulate state transitions and find a minimum-cost plan."]}]
3f:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":"Tier_2 actions delegate to an LLM agent. The planner hands off to ava or another agent to decide what to do. This is appropriate when the required action is contextual — it depends on information outside the world state (e.g. reading a CI log, understanding a PR description)."}]
40:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":"Most production goals should be tier_0 (alert) + tier_0 (ceremony trigger). Tier_1 and tier_2 are for workflows that require multi-step recovery or autonomous judgment."}]
