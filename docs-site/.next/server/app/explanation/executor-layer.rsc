24:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":[["$","code",null,{"className":"nextra-code","dir":"ltr","children":"AgentRuntimePlugin"}]," and ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"SkillBrokerPlugin"}]," are pure registrars. They have no bus subscriptions. Their entire ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"install()"}]," method creates executors and calls ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"registry.register()"}],". Their ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"uninstall()"}]," does nothing to the bus."]}]
25:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":"This is intentional. Subscriptions create coupling: a subscriber that handles a topic “owns” that topic and conflicts with other subscribers. Registrars have no such coupling — two registrars can coexist safely, registering different executors for different skills."}]
26:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":["The dispatch concern is entirely isolated in ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"SkillDispatcherPlugin"}],". Exactly one plugin subscribes to ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"agent.skill.request"}],". This makes it easy to reason about what happens when a skill request arrives: there is exactly one code path."]}]
