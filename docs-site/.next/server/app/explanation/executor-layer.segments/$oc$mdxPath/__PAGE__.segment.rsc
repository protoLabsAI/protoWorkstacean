but also subscribed to ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"message.inbound.#"}]," directly"]}],"\n"]}],"\n",["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":"This meant two plugins were racing for the same messages. Adding a third agent type (e.g. an in-process Claude Code SDK agent) would require a third subscriber with its own routing logic. There was no single place to ask “which agent handles this skill?”"}],"\n",["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":["The executor layer solves this by separating ",["$","strong",null,{"children":"registration"}]," from ",["$","strong",null,{"children":"dispatch"}],":"]}],"\n",["$","ul",null,{"className":"x:[:is(ol,ul)_&]:my-[.75em] x:not-first:mt-[1.25em] x:list-disc x:ms-[1.5em]","children":["\n",["$","li",null,{"className":"x:my-[.5em]","children":["Plugins that know about agents (",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"AgentRuntimePlugin"}],", ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"SkillBrokerPlugin"}],") register executors into ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"ExecutorRegistry"}]," at ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"install()"}]," time"]}],"\n",["$","li",null,{"className":"x:my-[.5em]","children":[["$","code",null,{"className":"nextra-code","dir":"ltr","children":"SkillDispatcherPlugin"}]," is the ",["$","strong",null,{"children":"sole subscriber"}]," to ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"agent.skill.request"}]," and delegates to the registry"]}],"\n",["$","li",null,{"className":"x:my-[.5em]","children":["Adding a new agent type means writing a new ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"IExecutor"}]," implementation and registering it — no changes to the dispatch path"]}],"\n"]}],"\n",["$","h2",null,{"id":"the-registrar-pattern","className":"x:tracking-tight x:text-slate-900 x:dark:text-slate-100 x:font-semibold x:target:animate-[fade-in_1.5s] x:mt-10 x:border-b x:pb-1 x:text-3xl nextra-border","children":["The registrar pattern","$L6"]}],"\n","$L7","\n","$L8","\n","$L9","\n","$La","\n","$Lb","\n","$Lc","\n","$Ld","\n","$Le","\n","$Lf","\n","$L10","\n","$L11","\n","$L12","\n","$L13","\n","$L14","\n","$L15"]}]]}]]}]}],null,"$L16"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"aIlg1q43siquEH60mCfm_"}
