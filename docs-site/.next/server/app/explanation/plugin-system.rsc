2d:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":["Direct plugin-to-plugin calls create invisible dependencies. If ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"CeremonyPlugin"}]," calls ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"SkillDispatcherPlugin.dispatch()"}]," directly, then CeremonyPlugin can’t be tested in isolation, can’t be replaced, and CeremonyPlugin must be loaded after SkillDispatcherPlugin. These dependencies compound."]}]
2e:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":"The bus forces all communication through a single, inspectable channel. The consequence is:"}]
