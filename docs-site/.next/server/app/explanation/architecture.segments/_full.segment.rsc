2b:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":["The executor layer is the unified dispatch path for all agent skill calls. Before it existed, ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"AgentPlugin"}]," and ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"A2APlugin"}]," both subscribed to ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"agent.skill.request"}]," and raced for messages. Adding a third agent type required a third subscriber."]}]
