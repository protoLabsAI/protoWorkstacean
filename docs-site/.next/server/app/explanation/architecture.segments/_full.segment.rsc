24:T9a4,flowchart TD\n    subgraph Surfaces["External Surfaces"]\n        GH[GitHub webhooks]\n        DC[Discord gateway]\n        PL[Plane webhooks]\n        HTTP["HTTP API :3000\n/publish · /api/*"]\n        MCP["MCP Server\n(Claude Code agents)"]\n    end\n\n    BUS[("Event Bus\nin-process pub/sub\nhierarchical topics")]\n\n    subgraph Adapters["Interface Plugins"]\n        GHP[GitHubPlugin]\n        DCP[DiscordPlugin]\n        PLP[PlanePlugin]\n    end\n\n    subgraph Routing["Skill Routing"]\n        RTP["RouterPlugin\nmessage.inbound.# + cron.#\n→ agent.skill.request"]\n        SDP["SkillDispatcherPlugin\nagent.skill.request subscriber\n(sole consumer)"]\n        REG["ExecutorRegistry\nresolve(skill, targets)"]\n    end\n\n    subgraph Registrars["Registrars (install-time only)"]\n        ART["AgentRuntimePlugin\nworkspace/agents/*.yaml\n→ ProtoSdkExecutor"]\n        SKB["SkillBrokerPlugin\nworkspace/agents.yaml\n→ A2AExecutor"]\n    end\n\n    subgraph Executors["Executor implementations"]\n        PSE["ProtoSdkExecutor\nClaude Code SDK\nin-process"]\n        A2AE["A2AExecutor\nHTTP JSON-RPC 2.0\nX-Correlation-Id · X-Parent-Id"]\n    end\n\n    subgraph WorldEngine["World Engine"]\n        WSE["WorldStateEngine\ngeneric domain poller\nregisterDomain(name, collector, tickMs)"]\n        DD["domain-discovery\nprojects.yaml → workspace/domains.yaml\nworkspace/actions.yaml"]\n        GEP["GoalEvaluatorPlugin\nworkspace/goals.yaml"]\n        PL0["PlannerPluginL0\nActionRegistry"]\n        ADP["ActionDispatcherPlugin\nWIP limit: 5"]\n    end\n\n    subgraph Ava["ava (protoMaker)"]\n        AVA_A2A["POST /a2a\nJSON-RPC 2.0"]\n        AVA_WORLD["/api/world/board\n/api/world/agent-health"]\n    end\n\n    GH --> GHP\n    DC --> DCP\n    PL --> PLP\n    HTTP --> BUS\n    MCP --> BUS\n\n    GHP & DCP & PLP --> BUS\n\n    BUS -- "message.inbound.#\ncron.#" --> RTP\n    RTP -- "agent.skill.request" --> BUS\n    BUS -- "agent.skill.request" --> SDP\n    SDP --> REG\n    REG --> PSE & A2AE\n\n    ART -- "register ProtoSdkExecutor" --> REG\n    SKB -- "register A2AExecutor" --> REG\n\n    A2AE --> AVA_A2A\n\n    DD -- "registerDomain\nupsert(action)" --> WSE\n    WSE -- "HTTP poll" --> AVA_WORLD\n    WSE -- "world.state.updated" --> GEP\n    GEP -- "world.goal.violated" --> BUS\n    BUS --> PL0\n    PL0 -- "world.action.plan" --> BUS\n    BUS --> ADP\n    ADP -- "agent.skill.request\nceremony.*.execute\nmessage.outbound.*" --> BUS5:["$","div",null,{"className":"x:mx-auto x:flex x:max-w-(--nextra-content-width)","children":["$","$L1f",null,{"value":[{"value":"System overview","id":"system-overview","depth":2},{"value":"The event bus","id":"the-event-bus","depth":2},{"value":"Executor layer","id":"executor-layer","depth":2},{"value":"World Engine — GOAP homeostatic loop","id":"world-engine--goap-homeostatic-loop","depth":2},{"value":"Distributed tracing","id":"distributed-tracing","depth":2},{"value":"Message routing conventions","id":"message-routing-conventions","depth":2}],"children":[["$","$L20",null,{}],["$","$L21",null,{"metadata":{"title":"Architecture","filePath":"../docs/explanation/architecture.md"},"bottomContent":"$undefined","sourceCode":"$undefined","children":[["$","div",null,{"id":"nextra-skip-nav"}],["$","main",null,{"data-pagefind-body":true,"children":[["$","h1",null,{"id":"$undefined","className":"x:tracking-tight x:text-slate-900 x:dark:text-slate-100 x:font-bold x:mt-2 x:text-4xl","children":["Architecture","$undefined"]}],"\n",["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":["$","em",null,{"children":"Conceptual overview of how protoWorkstacean’s components connect and why they are designed the way they are."}]}],"\n",["$","hr",null,{"className":"x:my-[2em] nextra-border"}],"\n",["$","h2",null,{"id":"system-overview","className":"x:tracking-tight x:text-slate-900 x:dark:text-slate-100 x:font-semibold x:target:animate-[fade-in_1.5s] x:mt-10 x:border-b x:pb-1 x:text-3xl nextra-border","ch