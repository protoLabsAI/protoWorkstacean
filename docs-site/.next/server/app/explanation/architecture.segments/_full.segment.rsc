27:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":["The bus is the only communication channel. No plugin talks directly to another plugin — everything goes through ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"bus.publish()"}]," and ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"bus.subscribe()"}],". Topic matching is hierarchical: ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"#"}]," matches anything, ",["$","code",null,{"className":"nextra-code","dir":"ltr","children":"*"}]," matches one segment."]}]
28:["$","p",null,{"className":"x:not-first:mt-[1.25em] x:leading-7","children":"This constraint is what makes the system composable. Adding Discord support doesn’t touch the GitHub plugin. Adding a new executor type doesn’t touch the routing logic. Plugins are independently installable and testable."}]
