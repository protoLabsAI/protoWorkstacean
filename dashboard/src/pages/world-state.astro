---
import DashboardLayout from "../layouts/DashboardLayout.astro";
---

<DashboardLayout title="World State" activePage="world-state">
  <div class="page-header">
    <h2>World State Snapshot</h2>
    <p class="subtitle">Live GOAP world state from all registered domains</p>
  </div>

  <div id="world-state-container">
    <div class="card">
      <p class="placeholder-content">Loading world state…</p>
    </div>
  </div>
</DashboardLayout>

<script>
  async function loadWorldState() {
    const container = document.getElementById("world-state-container");
    if (!container) return;
    try {
      const res = await fetch("/api/world-state");
      const data = await res.json();
      container.innerHTML = `
        <div class="card">
          <div class="card-title">Snapshot</div>
          <pre>${JSON.stringify(data, null, 2)}</pre>
        </div>
      `;
    } catch (err) {
      container.innerHTML = `
        <div class="card">
          <p class="placeholder-content">Failed to load world state</p>
        </div>
      `;
    }
  }

  loadWorldState();
  setInterval(loadWorldState, 5000);
</script>

<style>
  .page-header {
    margin-bottom: 24px;
  }

  .page-header h2 {
    font-size: 20px;
    margin-bottom: 4px;
  }

  .subtitle {
    color: var(--text-secondary);
    font-size: 13px;
  }
</style>
