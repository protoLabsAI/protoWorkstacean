---

<DashboardLayout title="Projects" activePage="projects">
  <div class="page-header">
    <h2>Projects</h2>
    <p class="subtitle">Registered projects in the workspace</p>
  </div>

  <div id="projects-container">
    <div class="card">
      <p class="placeholder-content">Loading projects…</p>
    </div>
  </div>
</DashboardLayout>

<script>
  async function loadProjects() {
    const container = document.getElementById("projects-container");
    if (!container) return;
    try {
      const res = await fetch("/api/projects");
      const json = await res.json() as { success?: boolean; data?: unknown[] };
      const projects = json.data ?? [];

      if (!Array.isArray(projects) || projects.length === 0) {
        container.innerHTML = `
          <div class="card">
            <p class="placeholder-content">No projects found</p>
          </div>
        `;
        return;
      }

      container.innerHTML = `
        <div class="projects-grid">
          ${projects
            .map(
              (p: Record<string, unknown>) => `
            <div class="card project-card">
              <div class="project-name">${p.name ?? p.id ?? "Unknown"}</div>
              ${p.description ? `<p class="project-desc">${p.description}</p>` : ""}
              ${p.status ? `<span class="badge badge-blue">${p.status}</span>` : ""}
            </div>
          `
            )
            .join("")}
        </div>
      `;
    } catch {
      container.innerHTML = `
        <div class="card">
          <p class="placeholder-content">Failed to load projects</p>
        </div>
      `;
    }
  }

  loadProjects();
</script>

<style>
