---

<DashboardLayout title="Events" activePage="events">
  <div class="page-header">
    <h2>Event Stream</h2>
    <p class="subtitle">Real-time bus events from all plugins</p>
  </div>

  <div class="toolbar">
    <input
      type="text"
      id="topic-filter"
      placeholder="Filter by topic (e.g. agent.*)"
      class="filter-input"
    />
    <button id="clear-btn" class="btn">Clear</button>
  </div>

  <div id="events-list" class="events-list">
    <p class="placeholder-content">Waiting for events…</p>
  </div>
</DashboardLayout>

<script>
  const list = document.getElementById("events-list")!;
  const filterInput = document.getElementById(
    "topic-filter"
  ) as HTMLInputElement;
  const clearBtn = document.getElementById("clear-btn")!;

  const events: Array<{ topic: string; payload: unknown; timestamp: string }> =
    [];

  function render() {
    const filter = filterInput.value.trim().toLowerCase();
    const filtered = filter
      ? events.filter((e) => e.topic.toLowerCase().includes(filter))
      : events;

    if (filtered.length === 0) {
      list.innerHTML = '<p class="placeholder-content">No events yet…</p>';
      return;
    }

    list.innerHTML = filtered
      .slice(0, 200)
      .map(
        (e) => `
        <div class="event-row">
          <span class="event-topic">${e.topic}</span>
          <span class="event-time">${new Date(e.timestamp).toLocaleTimeString()}</span>
          <details class="event-detail">
            <summary>payload</summary>
            <pre>${JSON.stringify(e.payload, null, 2)}</pre>
          </details>
        </div>
      `
      )
      .join("");
  }

  // Live WebSocket feed
  const proto = location.protocol === "https:" ? "wss" : "ws";
  const ws = new WebSocket(`${proto}://${location.host}/ws`);
  ws.addEventListener("message", (e) => {
    try {
      const msg = JSON.parse(e.data);
      events.unshift({
        topic: msg.topic ?? "unknown",
        payload: msg.payload ?? msg,
        timestamp: msg.timestamp ?? new Date().toISOString(),
      });
      if (events.length > 500) events.length = 500;
      render();
    } catch {}
  });

  filterInput.addEventListener("input", render);
  clearBtn.addEventListener("click", () => {
    events.length = 0;
    render();
  });
</script>

