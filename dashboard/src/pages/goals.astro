<script>
  async function loadGoals() {
    const container = document.getElementById("goals-container");
    if (!container) return;
    try {
      const res = await fetch("/api/world-state");
      const data = await res.json();
      const goals = data?.goals ?? data?.data?.goals ?? [];

      if (!Array.isArray(goals) || goals.length === 0) {
        container.innerHTML = `
          <div class="card">
            <p class="placeholder-content">No goals found</p>
          </div>
        `;
        return;
      }

      container.innerHTML = goals
        .map(
          (g: Record<string, unknown>) => `
          <div class="card goal-card">
            <div class="goal-header">
              <span class="goal-name">${g.name ?? g.id ?? "Unknown"}</span>
              <span class="badge badge-blue">${g.status ?? "unknown"}</span>
            </div>
            ${g.description ? `<p class="goal-desc">${g.description}</p>` : ""}
          </div>
        `
        )
        .join("");
    } catch {
      container.innerHTML = `
        <div class="card">
          <p class="placeholder-content">Failed to load goals</p>
        </div>
      `;
    }
  }

  loadGoals();
  setInterval(loadGoals, 10000);
</script>

