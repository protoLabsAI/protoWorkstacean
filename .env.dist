# OpenAI-compatible API (local Llama.cpp or Ollama)
OPENAI_BASE_URL=http://localhost:8080/v1
OPENAI_API_KEY=sk-dummy

# Signal bridge (bbernhard REST API)
SIGNAL_URL=https://admin:password@signal.example.com
SIGNAL_NUMBER=+1234567890

# Debug mode (1 or true to enable)
DEBUG=0

# Built-in plugins (comma-separated, disabled by default)
# Available: echo
ENABLED_PLUGINS=

# Agent workspace directory (relative to cwd or absolute path)
# In Docker with compose, set to /workspace with a named volume
WORKSPACE_DIR=./workspace

# Data directory for SQLite events.db (relative to cwd or absolute path)
# In Docker with compose, set to /data with a named volume
DATA_DIR=./data

# Graphiti — temporal user memory sidecar
# In production (homelab-iac/stacks/ai), graphiti connects to the shared
# neo4j in homelab-iac/stacks/infra over infra_default. Locally, default
# to `bolt://neo4j:7687` for a sibling container in the same compose, or
# point at your dev neo4j via Tailscale.
GRAPHITI_URL=http://graphiti:8000
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Model overrides for Graphiti (defaults to OpenAI; swap for local gateway)
GRAPHITI_MODEL=gpt-4o-mini
GRAPHITI_EMBEDDING_MODEL=text-embedding-3-small

# Model configuration is in models.json (in repo root)
# Pi SDK uses in-memory auth configured via models.json and OPENAI_API_KEY

# ── HTTP API + A2A server ──────────────────────────────────────────────────────
# Port the internal HTTP server listens on. Exposes:
#   GET  /.well-known/agent-card.json   (A2A discovery)
#   POST /a2a                           (A2A JSON-RPC endpoint)
#   POST /api/a2a/callback/:taskId      (push-notification webhooks)
#   POST /publish, /api/*               (internal API)
WORKSTACEAN_HTTP_PORT=3000

# API key required for authenticated endpoints. Gates /publish + POST /a2a.
# Unset → auth skipped (dev mode).
WORKSTACEAN_API_KEY=

# Externally-reachable URL stamped into A2A push-notification callbacks
# (registered as ${WORKSTACEAN_BASE_URL}/api/a2a/callback/{taskId} with remote
# agents that advertise capabilities.pushNotifications). Unset → silent
# fallback to polling.
# Example: http://workstacean:3000 (Docker net) or https://ava.proto-labs.ai
WORKSTACEAN_BASE_URL=

# Canonical externally-reachable base URL advertised in the A2A agent card
# (/.well-known/agent-card.json). When set, the card's `url` becomes
# ${WORKSTACEAN_PUBLIC_BASE_URL}/a2a — the URL spec-compliant clients hit
# after card discovery. Use this for cross-host or external callers.
# Unset → defaults to http://${WORKSTACEAN_INTERNAL_HOST:-workstacean}:${WORKSTACEAN_HTTP_PORT}/a2a
# Example: https://ava.proto-labs.ai
WORKSTACEAN_PUBLIC_BASE_URL=

# Docker-network hostname advertised in the agent card when
# WORKSTACEAN_PUBLIC_BASE_URL is unset. Defaults to "workstacean" — the
# compose service name. Override only if your service runs under a different
# name on the docker network.
WORKSTACEAN_INTERNAL_HOST=
