# ── GitHub integration config ────────────────────────────────────────────────
#
# Copy this to workspace/github.yaml and edit. Read by lib/plugins/github.ts
# on install and hot-reloaded on file change. The set of monitored repos is
# read live from the project registry (protoMaker) — never listed here.

# The bot handle admins use to mention in issue/PR comments. Case-insensitive.
# Use a dedicated handle (e.g. @protoquinn) to avoid colliding with real
# GitHub usernames.
mentionHandle: "@protoquinn"

# Admins whose @mentions are accepted by the trusted path. Non-admin
# @mentions are ignored.
admins:
  - your-github-username

# Per-event skill routing for the @mention path. Only @mentions from admins
# reach an agent here.
#
# Issues on registered project repos are NOT auto-triaged by workstacean —
# ProtoMakerBoardBridge forwards github.issue.opened into protoMaker's board
# intake, and protoMaker owns decomposition/triage (ADR-0001). Registry
# membership is the single ownership boundary, so an issue is never
# double-handled (JOSH-392). Workstacean's standing GitHub job is Quinn's
# pull_request auto-review (no @mention needed).
skillHints:
  issues: bug_triage
  issue_comment: bug_triage
  pull_request: pr_review
  pull_request_review_comment: pr_review
